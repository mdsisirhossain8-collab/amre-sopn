{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "discount": { "type": "number" },
        "rating": { "type": "number" },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "type": { "type": "string", "enum": ["image", "video"] }
            }
          }
        },
        "description": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "orderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteContent": {
      "title": "SiteContent",
      "description": "Global site settings and content",
      "type": "object",
      "properties": {
        "heroSubtitle": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroPromo": { "type": "string" },
        "heroImages": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of chat messages"
    },
    "/simulatedUsers/{userId}": {
      "schema": "object",
      "description": "Collection of simulated users for the demo"
    },
    "/siteContent/main": {
      "schema": "SiteContent",
      "description": "Singleton for site content"
    }
  }
}
